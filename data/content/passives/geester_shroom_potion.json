{
  "passives": {
    "geester_shroom_potion": {
      "name": "Geester Shroom Potion",
      "trigger_event": "on_create",
      "effects": [
        {
          "type": "apply_status",
          "status": "geester_shroom_passive",
          "duration": 999,
          "target": "self",
          "hooks": {
            "on_battle_start": [
              {
                "type": "add_stack",
                "stack": "shroom_potion",
                "amount": 2,
                "target": "self"
              }
            ],
            "on_target_action_end": [
              {
                "type": "conditional",
                "condition": {
                  "type": "all",
                  "conditions": [
                    { "type": "is_event_target", "target": "self" },
                    { "type": "hp_pct_below", "value": 0.5 },
                    {
                      "type": "stack_lte",
                      "stack": "geester_second_wind",
                      "value": 0
                    }
                  ]
                },
                "then": [
                  {
                    "type": "heal_max_hp_pct",
                    "pct": 1.0,
                    "target": "self"
                  },
                  {
                    "type": "add_stack",
                    "stack": "geester_second_wind",
                    "amount": 1,
                    "target": "self"
                  }
                ]
              }
            ],
            "on_active_skill_used": [
              {
                "type": "sequence",
                "effects": [
                  {
                    "type": "consume_stack",
                    "stack": "shroom_potion",
                    "amount": 1,
                    "target": "self"
                  },
                  {
                    "type": "add_stack",
                    "stack": "polymer_essence",
                    "amount": 1,
                    "target": "self"
                  },
                  {
                    "type": "conditional",
                    "condition": {
                      "type": "stack_lte",
                      "stack": "shroom_potion",
                      "value": 0
                    },
                    "then": [
                      {
                        "type": "apply_status",
                        "status": "bloomed",
                        "duration": 999
                      },
                      {
                        "type": "heal_max_hp_pct",
                        "pct": 0.5,
                        "target": "self"
                      },
                      {
                        "type": "add_stack",
                        "stack": "polymer_essence",
                        "amount": 2,
                        "target": "self"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  }
}
